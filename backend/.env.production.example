# ============================================================
# 本番（共有サーバー）用 .env テンプレート
# このファイルを .env にリネームし、各値を本番のものに置き換えて
# public_html/server/.env として FTP アップロードする
# ============================================================

# --- Database（Xserver の MySQL 情報に置き換え）---
# 重要: Xserver は DB_HOST が localhost ではない。
#       サーバーパネル「MySQL設定」に表示される mysqlXXXX.xserver.jp を指定する。
# 重要: DB名/ユーザー名は「アカウント名_xxxx」の形式で発行される。
DB_HOST=mysqlXXXX.xserver.jp
DB_PORT=3306
DB_DATABASE=__アカウント名_本番DB名__
DB_USERNAME=__アカウント名_本番DBユーザー__
DB_PASSWORD=__本番DBパスワード__

# --- Application ---
APP_ENV=production
APP_DEBUG=false
APP_URL=https://__本番ドメイン__/api

# --- Frontend URL（メール内リンク用。末尾スラッシュ無し）---
FRONTEND_URL=https://__本番ドメイン__

# --- メール内ロゴ画像URL（未設定時は FRONTEND_URL/images/nohoke_logo.png を使用）---
MAIL_LOGO_URL=

# --- JWT（本番用のランダムな値に必ず変更）---
JWT_SECRET=__ランダムな本番シークレットに変更__

# --- Mail (SMTP) ---
# 共有サーバーの SMTP 制限に注意。送信専用アカウント推奨
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=__送信用アカウント__
MAIL_PASSWORD=__アプリパスワード__
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=__送信元アドレス__
MAIL_FROM_NAME=NoHoKe

# --- Google スプレッドシート記録（無料/有料 完了ログ）---
# スプレッドシート(hohoke_user_log)に紐付けた Apps Script Web アプリの /exec URL。
# 空にすると記録を無効化する。
SHEET_LOG_URL=

# --- 今後設定予定 ---
RESEND_API_KEY=
TIMEREX_API_KEY=
